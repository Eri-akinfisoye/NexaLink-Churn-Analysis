	/// Churn rate for customers WITHOUT a selected service, using Driver Table for dynamic service selection
	measure 'Churn Rate Without Service' =
			// Dynamic churn rate for customers without a selected service
			VAR DriverSelected =
			    SELECTEDVALUE('Driver Table'[Driver])
			
			RETURN
			SWITCH(
			    DriverSelected,
			
			    "Online Security",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Online_Security] = "No"
			        ),
			
			    "Tech Support",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Tech_Support] = "No"
			        ),
			
			    "Online Backup",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Online_Backup] = "No"
			        ),
			
			    "Device Protection",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Device_Protection] = "No"
			        ),
			
			    "Streaming TV",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Streaming_TV] = "No"
			        ),
			
			    "Streaming Movies",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Streaming_Movies] = "No"
			        )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Services
		lineageTag: 0f97b210-1af9-4c3e-8e21-3cba96e6e777

	/// Churn rate for customers WITH a selected service, using Driver Table for dynamic service selection
	measure 'Churn Rate With Service' =
			// Dynamic churn rate for customers with a selected service
			VAR DriverSelected =
			    SELECTEDVALUE('Driver Table'[Driver])
			
			RETURN
			SWITCH(
			    DriverSelected,
			
			    "Online Security",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Online_Security] = "Yes"
			        ),
			
			    "Tech Support",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Tech_Support] = "Yes"
			        ),
			
			    "Online Backup",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Online_Backup] = "Yes"
			        ),
			
			    "Device Protection",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Device_Protection] = "Yes"
			        ),
			
			    "Streaming TV",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Streaming_TV] = "Yes"
			        ),
			
			    "Streaming Movies",
			        CALCULATE(
			            [Churn Rate%],
			            dim_services[Has_Streaming_Movies] = "Yes"
			        )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Services
		lineageTag: c21258ff-bbd4-42ef-b6d7-00e22a471250

