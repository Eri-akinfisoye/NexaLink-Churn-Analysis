		lineageTag: a77a9f14-f866-493c-ae79-b36853e56ee0

	measure 'Charge Band Color' = ```
			
			VAR MaxChurn = 
			    CALCULATE(
			        MAXX(
			            VALUES(dim_billing[Charge Band Monthly]), 
			            [Churn Rate%]
			        ), 
			        REMOVEFILTERS(
			            dim_billing[Charge Band Monthly], 
			            dim_billing[Charge Band Sort Column] -- Removes the hidden sort filter
			        )
			    )
			
			RETURN
			    IF( [Churn Rate%] < MaxChurn,  "#D5DBED
			","#343C53
			")
			
			```
		displayFolder: Charge Bands
		lineageTag: acca48b7-e734-47c5-8177-4b5ec97d3d65

	measure 'Measure 3'
		displayFolder: Charge Bands
		lineageTag: 76baedd3-beda-47cd-a2f0-c326c3032a9a

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	measure 'Data Bar Graphic' = ```
			
			// VAR BarLength = ROUND([Churn Rate%] * 43, 0) -- Adjust multiplier to fit your column width
			// RETURN
			//     REPT("█", BarLength)
			
			
			-- 1. Find the highest churn rate across all charge bands (accounting for the sort column)
			VAR MaxChurn = 
			    CALCULATE(
			        [Churn Rate%], 
			        TOPN(1, ALL(dim_billing[Charge Band Monthly], dim_billing[Charge Band Sort Column]), [Churn Rate%], DESC)
			    )
			
			-- 2. Define how many blocks long the LARGEST bar should be (e.g., 15 blocks wide)
			VAR MaxBarLength = 8
			
			-- 3. Calculate this row's length proportional to the maximum value
			VAR CurrentBarLength = 
			    IF(
			        NOT(ISBLANK([Churn Rate%])) && MaxChurn > 0,
			        ROUND(([Churn Rate%] / MaxChurn) * MaxBarLength, 0),
			        0
			    )
			
			RETURN
			    REPT("█", CurrentBarLength)
			
			```
		displayFolder: Charge Bands
		lineageTag: 415fce45-86fc-40c8-8500-d9ce72507361

	measure 'Charge Band Color(Font)' = ```
			
