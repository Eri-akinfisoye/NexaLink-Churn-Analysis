	/// Percentage of total revenue amount that was lost to churned customers. Similar to '% of All Churned Customers' but measures revenue impact instead of customer count.
	measure '% of Amount Churned' =
			// Calculates the percentage of total revenue amount that was lost to churn
			// VAR Total_Amount = CALCULATE(SUM(fact_churn[Total_Charge_USD]), REMOVEFILTERS(dim_customer))
			// VAR Churned_Amount = CALCULATE(SUM(fact_churn[Total_Charge_USD]), REMOVEFILTERS(dim_customer), fact_churn[Churned] = 1)
			// VAR Pct_Amount_Churned = DIVIDE(Churned_Amount, Total_Amount)
			
			// RETURN
			//     Pct_Amount_Churned
			
			VAR Total_Amount_Churned = CALCULATE([Amount Lost(Monthly) to Churn], ALL(dim_customer))
			VAR Churned_Amount = [Amount Lost(Monthly) to Churn]
			VAR Pct_Amount_Churned = DIVIDE( Churned_Amount, Total_Amount_Churned)
			
			RETURN
			Pct_Amount_Churned
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Financial Impact
		lineageTag: 25362ea8-cd8c-427d-9339-1989e0c704fb

	/// Color measure for % of Amount Churned by Internet Type. Returns red if >= 50%, grey otherwise.
	measure '% of Amount Churned Color' =
			// Color measure for % of Amount Churned - Returns red if >= 50%, grey otherwise
			VAR Current_Pct = [% of Amount Churned]
			
			RETURN
			    IF(Current_Pct >= 0.5, "#E81B23", "#A6A6A6")
		displayFolder: Financial Impact
		lineageTag: 9c72672d-632c-4611-bc0f-82f7663d6b50

	measure Fiber_vs_DSL_Multiplier =
			
			VAR Fiber_Churn_Rate = CALCULATE( [Churn Rate%], dim_services[Internet_Service_Type_Updated] = "Fiber Optic" )
			VAR DSL_Churn_Rate = CALCULATE( [Churn Rate%], dim_services[Internet_Service_Type_Updated] = "DSL" )
			
			RETURN
			FORMAT(DIVIDE( Fiber_Churn_Rate, DSL_Churn_Rate, 0), "0.00\x")
		displayFolder: Services
		lineageTag: ff23aa29-1676-436c-a6b7-bc38bb0afafd

	measure 'Fiber vs No Internet Churn Multiple' =
			
			
			VAR Fiber_Churn_Rate = CALCULATE( [Churn Rate%], dim_services[Internet_Service_Type_Updated] = "Fiber Optic" )
			VAR No_Internet_Churn_Rate = CALCULATE( [Churn Rate%], dim_services[Internet_Service_Type_Updated] = "No internet" )
			
			RETURN
			FORMAT(DIVIDE( Fiber_Churn_Rate, No_Internet_Churn_Rate, 0), "0.00\x")
		displayFolder: Services
		lineageTag: 551aa1e3-d8fa-42f5-8bc6-2bc15d761e8a

	measure 'Fiber Optic Churn Amount' = ```
			
			    FORMAT(ROUND(CALCULATE([Amount Lost(Monthly) to Churn] , dim_services[Internet_Service_Type_Updated] = "Fiber Optic"), -3),"$#,##0,\k")
			    
			```
