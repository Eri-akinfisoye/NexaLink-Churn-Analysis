/// Dedicated table to store all DAX measures for the NexaLink Churn Analysis project
table 'Measure Table'
	lineageTag: b5cba92f-f6aa-4c5d-9c19-142b096d09d8

	measure 'Total Number of Customers' = DISTINCTCOUNT(fact_churn[Customer_ID])
		formatString: 0
		displayFolder: Core KPIs
		lineageTag: 6df22c83-6f7e-4dc6-b6f6-7787e9e5e043

	measure 'Churned Customers' =
			
			CALCULATE(
			    DISTINCTCOUNT(fact_churn[Customer_ID]),
			    fact_churn[Churned] = "1"
			)
		formatString: 0
		displayFolder: Core KPIs
		lineageTag: dc6c9962-30d1-4c8f-be8b-0c04e1bf9f20

	measure 'Retained Customers' =
			
			CALCULATE(
			    DISTINCTCOUNT(fact_churn[Customer_ID]),
			    fact_churn[Churned] = "0"
			)
		formatString: 0
		displayFolder: Core KPIs
		lineageTag: 6ae2a6ff-cf88-4754-bc34-b608fa66d1bf

	measure 'Churn Rate%' = ```
			
			    DIVIDE(
			        [Churned Customers],
			        [Total Number of Customers],
			        0
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Core KPIs
		lineageTag: 16815f19-357e-4d0f-941c-3c1de7a87746

	measure 'Retention Rate%' = ```
			
			    1- [Churn Rate%]
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Core KPIs
		lineageTag: 494400c2-0850-407a-ba3f-9261cbfde590

	measure 'Total Number of Non-Senior Citizens' =
			
			CALCULATE(
			    COUNT(dim_customer[Senior Citizen Category]),
			    dim_customer[Senior Citizen Category] = "Non-senior Citizen"
			    )
		formatString: 0
		displayFolder: Demographics
		lineageTag: bdc8d32a-54df-4b5f-97b0-170771c69856

	measure 'Total Number of Senior Citizens' =
			
			[Total Number of Customers] - [Total Number of Non-Senior Citizens]
		formatString: 0
		displayFolder: Demographics
		lineageTag: 6215d487-b993-42ee-a0cf-d4d109ef9be5

	measure 'Senior Churn Rate %' = ```
			
			    CALCULATE(
			        [Churn Rate%],
			        dim_customer[Senior Citizen Category] = "Senior"
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Demographics
		lineageTag: a54972c6-59cb-4d82-b902-bbe144b7fbd9

	/// Churn rate for non-senior citizens: churned non-seniors divided by total non-seniors
	measure 'Non-Senior Churn Rate %' = ```
			
			    CALCULATE(
			        [Churn Rate%],
			        dim_customer[Senior Citizen Category] = "Non-senior"
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Demographics
		lineageTag: 86fb9bca-b87f-4e69-86fd-2aae4c0b92b8

	measure 'Average Tenure' =
			
			AVERAGE(dim_customer[Tenure_Months])
		displayFolder: Core KPIs
		lineageTag: babb8c6b-c283-46d3-940d-bc40f15d0548

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% of All Churned Customers' = ```
			
			// Tells us how much the band contributes to all the churned Customers 
			VAR Total_Customers = CALCULATE([Churned Customers], REMOVEFILTERS(dim_customer))
			VAR Pct_Churned = DIVIDE( [Churned Customers], Total_Customers)
			
			RETURN
			    Pct_Churned
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Core KPIs
		lineageTag: bd0975bd-370e-47d0-8818-be97e116803d

	measure 'Average Monthly Charge' = ```
			
			    AVERAGE(dim_billing[Monthly_Charge_USD])
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Core KPIs
		lineageTag: e159be68-dbaf-40df-897f-6b3985559743

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Average Total Charges' = ```
			
			    AVERAGE(dim_billing[Total_Charge_USD])
			    
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Core KPIs
		lineageTag: 9edbbd4a-4115-4c21-b15d-3beffd7879d6

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Median Monthly Charges' = ```
			
			
			    MEDIAN(dim_billing[Monthly_Charge_USD])
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Core KPIs
		lineageTag: 162e8253-eb1a-422c-a0e0-b131a9e110bb

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Median Total Charges' = ```
			
			
			    MEDIAN(dim_billing[Total_Charge_USD])
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Core KPIs
		lineageTag: 5d58109d-27d2-476e-b535-1f61269478f0

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '% of Total Customers' = ```
			
			
			    VAR Total_Customers = CALCULATE([Total Number of Customers], ALL(dim_customer))
			    VAR Pct_of_Customers = DIVIDE( [Total Number of Customers], Total_Customers , 0)
			    RETURN
			     Pct_of_Customers
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Core KPIs
		lineageTag: 1744a669-81f0-4277-beb9-96d42d1bba3f

	measure 'Totally Monthly Charges' =
			
			SUM(dim_billing[Monthly_Charge_USD])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Core KPIs
		lineageTag: 337a657f-7f0b-4ca8-8125-df22c7b80f89

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Amount Lost(Monthly) to Churn' = ```
			
			    CALCULATE(
			        SUM(dim_billing[Monthly_Charge_USD]),
			         fact_churn[Churn_Updated] = "Churned"
			    )
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Financial Impact
		lineageTag: 8ff62301-d130-4a39-a85d-86c76a931612

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure Zero_Pct = 0
		formatString: 0%;-0%;0%
		displayFolder: Labels & Formatting
		lineageTag: 5be91391-3224-4e88-86ee-0657ddd78ac2

	measure 100_Pct = 0.55
		formatString: 0%;-0%;0%
		displayFolder: Labels & Formatting
		lineageTag: e5fcf5b2-1b94-4456-8086-a5ec835d2d69

	measure Zero_Number = 0
		formatString: 0
		displayFolder: Labels & Formatting
		lineageTag: 97d450e8-4fd2-4e7c-9cda-f54d15cbb5f6

	measure 'Churn Ratio' = ```
			
			VAR Pct_All_Churned_Customers = 
			    [% of All Churned Customers] * 100 
			
			VAR Round_Up = ROUND(Pct_All_Churned_Customers,0)
			
			RETURN
			Round_Up
			```
		displayFolder: Labels & Formatting
		lineageTag: 74750c4f-411d-466d-aaa7-3f90ba24a35b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Customer Ratio' = ```
			
			    VAR Pct_All_Customers = 
			        [% of All Churned Customers] * 100
			    
			    VAR Rnd_Up = ROUNDUP(Pct_All_Customers,0)
			
			RETURN
			Rnd_Up
			```
		displayFolder: Labels & Formatting
		lineageTag: c1fc8df2-a306-4e04-8894-8e716614c0ef

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% of All Churned Retained' = ```
			
			// Tells us how much the band contributes to all the churned Customers 
			VAR Total_Customers = CALCULATE([Retained Customers], REMOVEFILTERS(dim_customer))
			VAR Pct_Retained = DIVIDE( [Retained Customers] ,Total_Customers)
			
			RETURN
			    Pct_Retained
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Core KPIs
		lineageTag: 09c03e95-71a7-49c4-8998-c67399099f08

	measure Pct_Diff_Churn = [100_Pct] - [% of All Churned Customers]
		displayFolder: Labels & Formatting
		lineageTag: 07f23f76-f467-425a-aa57-798bb63fa65e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Text of All churned' = ```
			
			    " | " & FORMAT([% of All Churned Customers], "0.0%") & " of all churn"
			```
		displayFolder: Labels & Formatting
		lineageTag: ef92a0ca-3a03-4dd7-8d9e-b4f1d864eca9

	measure 'Labels Placeholder' = ```
