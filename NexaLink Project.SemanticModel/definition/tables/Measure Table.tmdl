	measure 'Payment Method Relative Risk' = ```
			
			   // Calculates Lowest Churn
			    VAR lowestChurnRate =  CALCULATE(MINX(VALUES(dim_billing[Payment_Method_Cleaned]), [Churn Rate%]), REMOVEFILTERS(dim_billing[Payment_Method_Cleaned]))
			    // Returns Churn Category
			    VAR CurrentChurnRate = [Churn Rate%]
			    // Calculates Relativity
			    VAR Relativity = 
			        DIVIDE( CurrentChurnRate, lowestChurnRate,0)
			
			    RETURN
			    Relativity
			```
		formatString: 0.00x
		displayFolder: Contract & Billing
		lineageTag: e235ac9d-4319-464f-a04a-930a8dca60a0

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Risk Level Payment Method' = ```
			
			VAR CurrentRisk = [Payment Method Relative Risk]
			RETURN
			    SWITCH(
			        TRUE(),
			        CurrentRisk <= 1.00, "Lowest",
			        CurrentRisk <= 1.10, "Low",       CurrentRisk <= 1.5, "Moderate",
			    "Highest"
			    )
			
			```
		displayFolder: Contract & Billing
		lineageTag: 79bfb17b-fee5-478c-8a31-d48780d64fb7

	/// Churn rate for customers using traditional (non-paperless) billing
	measure 'Churn Rate - Traditional Billing' =
			// Churn rate for customers with traditional billing
			CALCULATE(
			    [Churn Rate%],
			    dim_billing[Uses_Paperless_Billing] = 0
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Contract & Billing
		lineageTag: 5ee0b695-3f61-4e54-9511-f7c068049b77

	/// Churn rate for customers using paperless billing
	measure 'Churn Rate - Paperless Billing' =
			// Churn rate for customers with paperless billing
			CALCULATE(
			    [Churn Rate%],
			    dim_billing[Uses_Paperless_Billing] = 1
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Contract & Billing
		lineageTag: b2a2b14d-db37-4c48-ba4f-7c3782f05ab6

	measure 'MAxx Billing' = ```
			
			   CALCULATE( MAXX(VALUES(dim_billing[Uses Paper Billing Updated]), [Churn Rate%]), REMOVEFILTERS(dim_billing[Uses Paper Billing Updated]))
			```
		displayFolder: Contract & Billing
		lineageTag: 6bfaad5c-c70a-490c-805b-94f7b09a0463

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Churn Rate Multiplier (Paperless Billing) 2' =
			// Calculates the multiplier (ratio) between churn rate for traditional billing vs paperless billing
			VAR Churn_Traditional_Billing = CALCULATE(
			    [Churn Rate%],
			    dim_billing[Uses_Paperless_Billing] = 0
			)
			VAR Churn_Paperless_Billing = CALCULATE(
			    [Churn Rate%],
			    dim_billing[Uses_Paperless_Billing] = 1
			)
			VAR Multiplier = FORMAT(DIVIDE(Churn_Paperless_Billing, Churn_Traditional_Billing),"0.00""x""")
			
			RETURN
			    Multiplier
		displayFolder: Contract & Billing
		lineageTag: b6e29ecb-f0fc-4b3b-891c-36e8be40a817

	measure Measure
		displayFolder: Contract & Billing
		lineageTag: 37e18b3f-27b2-4d6b-8f66-2f635743af0a

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	measure 'Type of billing color'
		displayFolder: Contract & Billing
		lineageTag: 2d4e9659-07cd-4248-bb3d-2232feff6552

	/// Color measure for payment method based on risk level. Lowest/Low = Green, Moderate = Orange, Highest = Red
	measure 'Payment Method Risk Level Color' =
			// Color measure for payment method risk level
			VAR RiskLevel = [Risk Level Payment Method]
			
			RETURN
			    SWITCH(
			        RiskLevel,
			        "Lowest", "#70AD47",        // Lowest Risk - Green
			        "Low", "#70AD47",            // Low Risk - Green
			        "Moderate", "#FFA500",       // Moderate Risk - Orange
			        "Highest", "#E81B23",        // Highest Risk - Red
			        "#D5DBED"                    // Default - Light Grey
			    )
		displayFolder: Contract & Billing
		lineageTag: 9d5ef890-1495-42ab-b2fc-befead6a4e11

	/// Color measure for retention opportunities impact level. Very High/High = Green, Medium = Orange, Low = Red
	measure 'Retention Opportunity Impact Color' =
			// Color measure for retention opportunities impact level
			VAR ImpactLevel = SELECTEDVALUE('Retention Opportunites'[Impact])
			
			RETURN
			    SWITCH(
			        ImpactLevel,
			        "Very High", "#70AD47",     // Very High Impact - Green
			        "High", "#70AD47",           // High Impact - Green
			        "Medium", "#FFA500",         // Medium Impact - Orange
			        "Low", "#E81B23",            // Low Impact - Red
			        "#D5DBED"                    // Default - Light Grey
			    )
		displayFolder: Labels & Formatting
		lineageTag: 0f714a5f-a9dc-46f5-809a-6157fdb87f60

	/// Relativity multiplier between Electronic Check and Bank Transfer churn rates
	measure 'Electronic Check vs Bank Transfer Relativity' =
			// Calculates how many times higher Electronic Check churn is vs Bank Transfer
			VAR Electronic_Check_Churn = CALCULATE(
			    [Churn Rate%],
			    dim_billing[Payment_Method_Cleaned] = "electronic check"
			)
			VAR Bank_Transfer_Churn = CALCULATE(
			    [Churn Rate%],
			    dim_billing[Payment_Method_Cleaned] = "bank transfer"
			)
			VAR Relativity = DIVIDE(Electronic_Check_Churn, Bank_Transfer_Churn)
			
			RETURN
			    Relativity
		formatString: 0.00x
		displayFolder: Contract & Billing
		lineageTag: 441776f6-e4cd-487a-a075-6ee3f2f719e6

	/// Relativity multiplier between Electronic Check and Credit Card churn rates
	measure 'Electronic Check vs Credit Card Relativity' =
			// Calculates how many times higher Electronic Check churn is vs Credit Card
			VAR Electronic_Check_Churn = CALCULATE(
			    [Churn Rate%],
			    dim_billing[Payment_Method_Cleaned] = "electronic check"
			)
			VAR Credit_Card_Churn = CALCULATE(
			    [Churn Rate%],
			    dim_billing[Payment_Method_Cleaned] = "credit card"
			)
			VAR Relativity = DIVIDE(Electronic_Check_Churn, Credit_Card_Churn)
			
			RETURN
			    Relativity
		formatString: 0.00x
		displayFolder: Contract & Billing
		lineageTag: 747248f6-96bb-4cc7-9fee-421498ff652a

	/// Percentage of total customer base in the current segment or dimension
	measure '% of Base Customers' = ```
			// Calculates the percentage of customers in the current segment relative to total customer base
			VAR Current_Segment_Customers = [Total Number of Customers]
			VAR Total_Base_Customers = CALCULATE(
			    [Total Number of Customers], ALL(dim_customer)
			)
			VAR Pct_Of_Base = DIVIDE(Current_Segment_Customers, Total_Base_Customers)
			
			RETURN
			    Pct_Of_Base
			
			    
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Core KPIs
		lineageTag: d083c711-2d0d-4dca-aeea-d6d17e1d5cbd

	measure 'Churn Rate% 2' =
			
			[Churn Rate%]
		formatString: 0.00%;-0.00%;0.00%
