	/// Calculates the median tenure in months for all customers
	measure 'Median Tenure (Months)' = MEDIAN(dim_customer[Tenure_Months])
		displayFolder: Tenure
		lineageTag: 701b1aa2-5ab8-40bc-a432-cbddc34fed45

	measure 'Median Tenure(Months) Label' = ```
			
			UNICHAR(11166) &  
			     " 50% of churn occurs before month " & CALCULATE([Median Tenure (Months)], fact_churn[Churn_Updated] = "Churned")
			```
		displayFolder: Tenure
		lineageTag: 35f167c8-8593-40a0-821c-582cfd1697e1

	measure 'Post Yr 1 churn rate Label' =
			
			
			UNICHAR(11166) & " Drops " & FORMAT([Churn Rate%], "0.00%")  &" after year 1 survival"
		displayFolder: Tenure
		lineageTag: 9194cdca-91bc-4919-b5e8-5d0c1250af00

	measure 'Year 1 & 2_Revenue_Loss' =
			
			CALCULATE(
			    [Amount Lost(Monthly) to Churn],
			    dim_customer[Tenure_Months] >= 0 && dim_customer[Tenure_Months] <= 24)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
