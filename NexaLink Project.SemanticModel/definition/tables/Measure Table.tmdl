	/// Percentage of churned customers that have Fiber Optic internet service
	measure '% of Churned Customers from Fiber Optics' =
			// Calculates the percentage of churned customers that are from Fiber Optics
			VAR Churned_Fiber_Customers = CALCULATE(
			    [Churned Customers],
			    dim_services[Internet_Service_Type_Updated]= "Fiber Optic"
			)
			VAR Total_Churned = [Churned Customers]
			VAR Pct_Churned_Fiber = DIVIDE(Churned_Fiber_Customers, Total_Churned)
			
			RETURN
			    Pct_Churned_Fiber
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Services
		lineageTag: 48d898f7-27bd-484d-b492-26188b33cd0b

	/// Percentage of total monthly churn amount contributed by Fiber Optic customers
	measure '% of Monthly Churn Amount from Fiber Optics' =
			// Calculates the percentage of total monthly churn amount from Fiber Optic customers
			VAR Churned_Fiber_Monthly = CALCULATE(
			[Amount Lost(Monthly) to Churn],
			    dim_services[Internet_Service_Type_Updated] = "Fiber Optic"
			)
			VAR Total_Churned_Monthly = [Amount Lost(Monthly) to Churn]
			VAR Pct_Amount_Churned_Fiber = DIVIDE(Churned_Fiber_Monthly, Total_Churned_Monthly)
			
			RETURN
			    Pct_Amount_Churned_Fiber
		formatString: 0%;-0%;0%
		displayFolder: Services
		lineageTag: 47fd8806-5a77-4e8d-acc0-c7fcf204adfa

	/// Percentage drop in churn rate between customers without and with online security
	measure 'Churn Rate % Drop (Online Security)' = ```
			// Calculates the percentage drop in churn rate between no online security vs has online security
			VAR Churn_Without_Security = CALCULATE(
			    [Churn Rate%],
			    dim_services[Has_Online_Security]= "No"
			)
			VAR Churn_With_Security = CALCULATE(
			    [Churn Rate%],
			    dim_services[Has_Online_Security] = "Yes"
			)
			VAR Pct_Drop = 
			FORMAT(DIVIDE(
			    Churn_Without_Security - Churn_With_Security,
			    Churn_Without_Security), "-0.00%") 
			
			
			RETURN
			  Pct_Drop  &    UNICHAR(11015)
			```
		displayFolder: Services
		lineageTag: 97f9a125-6029-4c08-b451-6744d734fbea

	/// Multiplier showing how many times higher the churn rate is for customers without vs with online security
	measure 'Churn Rate Multiplier (Online Security)' =
			// Calculates the multiplier (ratio) between churn rate without and with online security
			VAR Churn_Without_Security = CALCULATE(
			    [Churn Rate%],
			    dim_services[Has_Online_Security] = "No"
			)
			VAR Churn_With_Security = CALCULATE(
			    [Churn Rate%],
			    dim_services[Has_Online_Security] = "Yes"
			)
			VAR Multiplier = FORMAT(DIVIDE(Churn_Without_Security, Churn_With_Security), "0.00""x⬆""")
			
			RETURN
			    Multiplier
		displayFolder: Services
		lineageTag: d9d44870-887b-4f36-b2f9-468ebbb1b3af

	/// Percentage of total customer base that have Fiber Optic internet service
	measure '% of Customer Base from Fiber Optics' =
			// Calculates the percentage of customers with Fiber Optic internet service
			VAR Fiber_Customers = CALCULATE(
			    [Total Number of Customers],
			    dim_services[Internet_Service_Type_Updated] = "Fiber Optic"
			)
			VAR Total_Customers = [Total Number of Customers]
			VAR Pct_Fiber_Customers = FORMAT(DIVIDE(Fiber_Customers, Total_Customers), "0%")
			
			RETURN
			    Pct_Fiber_Customers & " of customers base"
		displayFolder: Services
		lineageTag: b96f247b-d897-46c4-9a8f-19c924248b30

