	measure 'Dashboard Insights' = ```
			
			UNICHAR(8226) & " Month-to-month customers churn at 15× the rate of two-year customers and account for 88.6% of all customers lost." & UNICHAR(10) &
			UNICHAR(8226) & "  Fiber optic customers churn at 41.89% and contribute 69.4% of all churned customers despite being only 44% of the base.
			" & 
			UNICHAR(8226) & " Raising just one support ticket triples churn probability from 19.69% to 65% — the first ticket is the most critical retention moment." & UNICHAR(10) &
			UNICHAR(8226) & " NexaLink's highest-risk profile combines all three drivers: fiber optic service, month-to-month contract, and active support tickets."
			```
		displayFolder: Labels & Formatting
