			```
		displayFolder: Demographics
		lineageTag: 6f2867e8-1e7b-4dd0-98b6-d8d977ca0e32

	measure 'Customers with Partners' = ```
			
			    CALCULATE([Total Number of Customers],
			      dim_customer[Has_Partner_Update] = "Yes"
			    )
			```
		formatString: 0
		displayFolder: Demographics
		lineageTag: 563330b7-d319-4d92-a140-6cf22cc2a020

	measure 'Customers without Partners' = ```
			
			    CALCULATE([Total Number of Customers],
			      dim_customer[Has_Partner_Update] = "No"
			    )
			```
		formatString: 0
		displayFolder: Demographics
		lineageTag: 0e06bbb7-286c-4faf-90c1-b1832424ecbd

	measure 'Customer without Dependents Label 1' = ```
			
			VAR Pct_of_Dependents = 
			    FORMAT(CALCULATE([% of Total Customers], 
			    dim_customer[Has_Dependents] = 0
			    ), "0%")
			
			RETURN
			UNICHAR(11166) & " " & Pct_of_Dependents & " of base customers "
			
			
			```
		displayFolder: Demographics
		lineageTag: 96723112-83c4-43b4-85ea-cea9831a1b38

	measure 'Customer withot Dependents Label 2' = ```
			
			        VAR WithDependentChurn = CALCULATE([Churn Rate%], dim_customer[Has_Dependents] = 1) *100
			        VAR WithoutDependentChurn = CALCULATE([Churn Rate%], dim_customer[Has_Dependents] = 0) * 100
			        VAR Ratio = FORMAT(DIVIDE( WithoutDependentChurn, WithDependentChurn),"0.00")
			
			        RETURN
			            UNICHAR(11166) & " " & Ratio & "x" & UNICHAR(8593) & " higher churn likelyhood"
			```
		displayFolder: Demographics
		lineageTag: bbca95f7-1c84-4ecb-a36c-bd25f2c3baa6

	measure 'Customers without Partners Label 1' = ```
			
			    Var WithoutPartnersPct =    FORMAT(CALCULATE( [% of All Churned Customers], dim_customer[Has_Partner_Update] = "No"), "0.00%")
			
			    RETURN
			   UNICHAR(11166)& " Accounts for " & WithoutPartnersPct & " of churn"
			
			
			```
		displayFolder: Demographics
		lineageTag: 65f664af-b7fc-49a6-ba9f-c7860cdfb4da

	measure 'Customers without Partners Label 2' = ```
			
			        VAR WithPartnersChurn = CALCULATE([Churn Rate%], dim_customer[Has_Partner_Update] = "Yes") *100
			        VAR WithoutPartners = CALCULATE([Churn Rate%], dim_customer[Has_Partner_Update] = "No") * 100
			        VAR Ratio = FORMAT(DIVIDE( WithoutPartners, WithPartnersChurn),"0.00")
			
			        RETURN
			            UNICHAR(11166) & " " & Ratio &"x"& UNICHAR(8593) &" higher churn likelyhood"
			```
		displayFolder: Demographics
		lineageTag: 58b75fdb-fcf7-464f-b3b4-d6d57aa0adb8

