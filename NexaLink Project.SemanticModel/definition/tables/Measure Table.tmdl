	measure Months_Label = " months"
		displayFolder: Tenure
		lineageTag: 1332bc58-7cb3-4e4b-a05b-c6feb99debd4

	measure 'Dynamic Space Measure For Bar Chart(Tenure Months)' =
			MAXX(
			    SUMMARIZE(
			        'fact_churn',
			        fact_churn[Churn_Updated],
			        "Avg Months", [Average Tenure Months]
			    ),
			    [Avg Months]
			) * 1.8
		displayFolder: Tenure
		lineageTag: 411bf221-95f1-43bb-b444-cbd6347d7fcf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Dynamic Space Measure For Bar Chart(Tenure Months_ChurnRate)' =
			MAXX(
			    SUMMARIZE(
			        'dim_customer',
			          dim_customer[Tenure_band]  ,
			        "ChurnPct", [Churn Rate%]
			    ),
			    [ChurnPct]
			) * 1.2
		displayFolder: Tenure
		lineageTag: 79bb46ed-50ef-4c1e-b805-e75d3730f211

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avergae Tenure Gap' = ```
			
			    VAR Avg_Churned = 
			            CALCULATE( [Average Tenure Months], fact_churn[Churn_Updated] = "Churned")
			      VAR Avg_Retained = 
			            CALCULATE( [Average Tenure Months], fact_churn[Churn_Updated] = "Retained")
			
			    RETURN
			    Avg_Retained - Avg_Churned 
			```
		displayFolder: Tenure
		lineageTag: 941032da-81c8-43d1-8c7e-4d5821f15fc6

