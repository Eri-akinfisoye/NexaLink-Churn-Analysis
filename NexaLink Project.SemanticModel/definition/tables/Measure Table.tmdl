	measure One_ = 1
		formatString: 0
		displayFolder: Labels & Formatting
		lineageTag: 2ac8981a-ccc2-42df-8bf3-67bc723d99f4

	/// Finds the maximum churn rate grouped by Partners & Dependants and multiplies by 1.5 to create dynamic spacing in bar charts
	measure 'Dynamic Space Measure For Bar Chart' =
			MAXX(
			    SUMMARIZE(
			        'fact_churn',
			        'dim_customer'[Partners & Dependents],
			        "MaxChurnRate", [Churn Rate%]
			    ),
			    [MaxChurnRate]
			) * 2
		displayFolder: Demographics
		lineageTag: c573061a-ec03-48df-b80d-e11f9b899f3b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Dynamic Space Measure For Bar Chart(Retained)' =
			MAXX(
			    SUMMARIZE(
			        'fact_churn',
			        'dim_customer'[Senior Citizen Category],
			        "MaxRetained", [Retained Customers]
			    ),
			    [MaxRetained]
			) * 1.8
		displayFolder: Demographics
		lineageTag: 88621ad8-cc7d-4a65-a7e0-859a55df5d3c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Senior VS Non-senior Insights' = ```
			
			
			UNICHAR(11166) & " Seniors are 16.2% of the base but account for 25.5% of all churned customers." & UNICHAR(10) &
			UNICHAR(11166) & "A senior is 1.77× more likely to churn than a non-senior customer." & UNICHAR(10) &
			UNICHAR(11166) & " Senior churn costs NexaLink $38,420 monthly — 27.6% of total revenue loss. "
			
			
			```
		displayFolder: Demographics
		lineageTag: 7fea7b8d-9dc5-43cd-9085-7043cbd0c90d

	measure 'Senior vs Non-Senior Churn Reference Label' = ```
			
			    VAR Val= FORMAT([Non-Senior Churn Rate %], "0.00%")
			
			    RETURN
			    UNICHAR(11166) & " VS " & Val & " Non-Senior "
			```
		displayFolder: Demographics
		lineageTag: 7e8852bc-ddfd-4c09-befa-d0af7954db53

	measure 'Gender Churn Gap' = ```
			
			VAR _Female_Churn = CALCULATE([Churn Rate%], dim_customer[Gender] = "Female") 
			VAR _Male_Churn   = CALCULATE([Churn Rate%], dim_customer[Gender] = "Male") 
			VAR _Gap          = (_Female_Churn - _Male_Churn) * 100 
			RETURN 
			FORMAT(_Gap, "0.00""pp""")
			
			```
		displayFolder: Demographics
		lineageTag: 65a88aa9-802c-462f-8d86-95d16fa79008

	measure 'Senior VS Non-Senior KPI (Label 2)' =
			
			UNICHAR(11166) & " 1.77×" &UNICHAR(8593) &" higher churn risk"
		displayFolder: Demographics
		lineageTag: 9ad46d69-2db4-4020-90a5-8d67f58072ed

	measure 'Gender Gap Label' = ```
			
			    VAR FemaleChurn = FORMAT(CALCULATE( [Churn Rate%], dim_customer[Gender] = "Female"), "0.00%")
			    VAR MaleChurn = FORMAT(CALCULATE( [Churn Rate%], dim_customer[Gender] = "Male"), "0.00%" )
			
			    RETURN
			    UNICHAR(11166) & " Female " & FemaleChurn & " vs" & " Male " & MaleChurn
			
			```
		displayFolder: Demographics
		lineageTag: 13edf17d-c301-49d4-bdba-6e62d634667d

	measure 'Gender Gap Label_2' =
			
			UNICHAR(11166) & " Not significant"
		displayFolder: Demographics
		lineageTag: 5617c05a-1c20-4e42-bb40-a1c326f5d5e1

	measure 'No of Customers with Dependents' = ```
			
			    CALCULATE([Total Number of Customers],
			      dim_customer[Has_Dependants_Updated] = "Yes"
			    )
			```
		formatString: 0
		displayFolder: Demographics
		lineageTag: 93704d29-3d74-4f46-af0a-f05f2e4bb497

	measure '% of Customers with dependants' = ```
			
			    Var DependantsPct = FORMAT(CALCULATE([% of Total Customers], dim_customer[Has_Dependants_Updated] = "Yes"), "0%")
			    
			    RETURN
			    UNICHAR(11166) & " " & DependantsPct & " of Total Customers"
			        
			```
		displayFolder: Demographics
