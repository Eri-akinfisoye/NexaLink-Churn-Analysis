model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["dim_billing","dim_customer","dim_services","dim_support","fact_churn","Retention Opportunites"]

annotation PBI_ProTooling = ["MCP-PBIModeling","DevMode"]

ref table dim_billing
ref table dim_customer
ref table dim_services
ref table dim_support
ref table fact_churn
ref table 'Measure Table'
ref table 'Driver Table'
ref table 'Retention Opportunites'

ref cultureInfo en-US

